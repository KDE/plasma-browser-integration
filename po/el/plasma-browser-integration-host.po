#, kde-format
msgctxt "NAME OF TRANSLATORS"
msgid "Your names"
msgstr "Πέτρος Βιδάλης"

#, kde-format
msgctxt "EMAIL OF TRANSLATORS"
msgid "Your emails"
msgstr "pvidalis@gmail.com"

#: downloadjob.cpp:138
#, kde-format
msgid ""
"This type of file can harm your computer. If you want to keep it, accept "
"this download from the browser window."
msgstr ""
"Αυτός ο τύπος αρχείου μπορεί να βλάψει τον υπολογιστή σας. Αν θέλετε να το "
"διατηρήσετε, αποδεχτείτε αυτή τη λήψη από το παράθυρο του περιηγητή."

#: downloadjob.cpp:235
#, kde-format
msgid "Access denied."
msgstr "Άρνηση πρόσβασης."

#: downloadjob.cpp:236
#, kde-format
msgid "Insufficient free space."
msgstr "Ανεπαρκής ελεύθερος χώρος."

#: downloadjob.cpp:237
#, kde-format
msgid "The file name you have chosen is too long."
msgstr "Το όνομα αρχείου που επιλέξατε είναι πολύ μεγάλο."

#: downloadjob.cpp:238
#, kde-format
msgid "The file is too large to be downloaded."
msgstr "Το αρχείο είναι πολύ μεγάλο για λήψη."

#: downloadjob.cpp:240
#, kde-format
msgid "The file possibly contains malicious contents."
msgstr "Το αρχείο πιθανόν να περιέχει κακόβουλο περιεχόμενο."

#: downloadjob.cpp:241
#, kde-format
msgid "A temporary error has occurred. Please try again later."
msgstr "Παρουσιάστηκε ένα προσωρινό σφάλμα. Προσπαθήστε πάλι αργότερα."

#: downloadjob.cpp:243
#, kde-format
msgid "A network error has occurred."
msgstr "Παρουσιάστηκε σφάλμα στο δίκτυο."

#: downloadjob.cpp:244
#, kde-format
msgid "The network operation timed out."
msgstr "Τέλος χρόνου της δικτυακής λειτουργίας."

#: downloadjob.cpp:245
#, kde-format
msgid "The network connection has been lost."
msgstr "Χάθηκε η σύνδεση με το δίκτυο."

#: downloadjob.cpp:246
#, kde-format
msgid "The server is no longer reachable."
msgstr "Ο εξυπηρετητής δεν είναι πλέον προσβάσιμος."

#: downloadjob.cpp:248
#, kde-format
msgid "A server error has occurred."
msgstr "Παρουσιάστηκε σφάλμα στον εξυπηρετητή."

#: downloadjob.cpp:252
#, kde-format
msgid "The server does not have the requested data."
msgstr "Ο εξυπηρετητής δεν διαθέτει τα απαιτούμενα δεδομένα."

#: downloadjob.cpp:254
#, kde-format
msgid "The browser application closed unexpectedly."
msgstr "Η εφαρμογή του περιηγητή τερματίστηκε απρόσμενα."

#: downloadjob.cpp:260
#, kde-format
msgid "An unknown error occurred while downloading."
msgstr "Παρουσιάστηκε άγνωστο σφάλμα κατά τη λήψη."

#: downloadjob.cpp:298
#, kde-format
msgctxt "Job heading, like 'Copying'"
msgid "Downloading"
msgstr "Λήψη"

#: downloadjob.cpp:299
#, kde-format
msgctxt "The URL being downloaded"
msgid "Source"
msgstr "Πηγή"

#: downloadjob.cpp:300
#, kde-format
msgctxt "The location being downloaded to"
msgid "Destination"
msgstr "Προορισμός"

#: historyrunnerplugin.cpp:108
#, kde-format
msgctxt "Dummy search result"
msgid "Additional permissions are required"
msgstr "Απαιτούνται πρόσθετες άδειες"

#: tabsrunnerplugin.cpp:38
#, kde-format
msgid "Mute Tab"
msgstr "Σίγαση καρτέλας"

#: tabsrunnerplugin.cpp:43
#, kde-format
msgid "Unmute Tab"
msgstr "Ενεργοποίηση ήχου καρτέλας"
